{
  "name": "paradise-gym-backend",
  "version": "1.0.0",
  "description": "Backend API cho hệ thống quản lý phòng gym Paradise GYM",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "init-db": "node init-db.js"
  },
  "keywords": [
    "gym",
    "api",
    "nodejs",
    "sqlite"
  ],
  "author": "Paradise GYM Team",
  "license": "ISC",
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "cloudinary": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1"
  },
  "nodemonConfig": {
    "ignore": [
      "database/*",
      "*.db",
      "*.db-journal",
      "*.db-wal",
      "scratch/*",
      "logs/*"
    ]
  }
}
